{
  "manifest_version": 3,
  "name": "YouTube Kid Limiter",
  "version": "1.0.6",
  "description": "Limits kids' YouTube time with a brain-energy meter and restful breaks. Parent settings are protected by a math exercise.",
  "permissions": [
    "alarms",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "content/overlay.js",
        "content/content.js"
      ],
      "css": [
        "content/overlay.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*"
      ],
      "matches": [
        "*://*.youtube.com/*"
      ]
    }
  ]
}
